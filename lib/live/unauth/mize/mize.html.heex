<Layouts.unauth_app flash={@flash} current_scope={@current_scope}>

<%!-- ============================
  LOADER
============================= --%>
<div id="loader" class="llm-loader-screen" aria-hidden="true" phx-hook="LoaderHook">
  <div class="llm-loader-inner">
    <div class="llm-loader-ring">
      <div class="llm-loader-spinner"></div>
      <div class="llm-loader-crown">
        <img src="/images/mize/mize_logo.png" alt="Makishi mask silhouette" class="llm-loader-mask" />
      </div>
    </div>
    <p class="llm-loader-title">LIKUMBI LYA MIZE</p>
    <p class="llm-loader-sub">THE MAKISHI AWAKENING</p>
  </div>
</div>

<%!-- ============================
  HERO
============================= --%>
<section class="llm-hero" id="hero">

  <%!-- Diagonal ceremonial-red shard --%>
  <div class="llm-hero-shard" aria-hidden="true"></div>

  <%!-- Ambient forest blobs --%>
  <div class="llm-blob llm-blob-1" aria-hidden="true"></div>
  <div class="llm-blob llm-blob-2" aria-hidden="true"></div>

  <%!-- Particle canvas --%>
  <canvas id="particles-hook" class="llm-particles-canvas" aria-hidden="true"
    phx-hook="Particles"></canvas>

  <%!-- Ground mist waves --%>
  <div class="llm-mist" aria-hidden="true">
    <svg class="llm-mist-wave llm-mist-1" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M0,60 C200,90 400,30 600,60 C800,90 1000,30 1200,60 L1200,120 L0,120 Z"
            fill="rgba(204,0,0,0.06)"/>
    </svg>
    <svg class="llm-mist-wave llm-mist-2" viewBox="0 0 1200 120" preserveAspectRatio="none">
      <path d="M0,40 C150,70 350,10 600,40 C850,70 1050,10 1200,40 L1200,120 L0,120 Z"
            fill="rgba(10,10,10,0.55)"/>
    </svg>
  </div>

  <div class="llm-hero-content" id="hero-content">
    <p class="llm-hero-eyebrow reveal">The Luvale Spirit Ceremony · Zambezi District</p>

    <h1 class="llm-hero-title reveal" style="--delay: 0.2s">
      LIKUMBI<br/>LYA MIZE
    </h1>

    <div class="llm-hero-divider reveal" style="--delay: 0.4s" aria-hidden="true">
      <span class="llm-divider-line"></span>
      <span class="llm-divider-icon">◈</span>
      <span class="llm-divider-line"></span>
    </div>

    <p class="llm-hero-desc reveal" style="--delay: 0.5s">
      When the ancestral Makishi spirits emerge from the sacred forest of Mize,
      the Luvale people of Northwestern Zambia are bound once more to their past,
      their initiation rites, and the living pulse of their identity.
    </p>

    <div class="llm-hero-cta reveal" style="--delay: 0.7s">
      <a href="/journey" class="llm-btn-primary">
        Enter the Forest <span class="llm-btn-arrow">→</span>
      </a>
      <button class="llm-btn-audio" id="audio-hook" phx-hook="AudioPlayer">
        <span class="llm-audio-bars" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span>
        </span>
        Ceremonial Drums
      </button>
    </div>
  </div>

  <div class="llm-scroll-hint reveal" style="--delay: 1s" aria-label="Scroll to explore">
    <span class="llm-scroll-chevron">↓</span>
  </div>
</section>

<%!-- ============================
  INTRODUCTION
============================= --%>
<section id="journey" class="llm-section llm-section-dark llm-section-forest">
  <div class="llm-container llm-grid-2col">

    <div class="llm-intro-text scroll-reveal">
      <div class="llm-badge">
        <span class="llm-badge-dot"></span>
        Living Ancestral Heritage
      </div>

      <h2 class="llm-section-title">
        The Festival of the <em class="llm-gold">Spirits</em>
      </h2>

      <p class="llm-body-text">
        Likumbi Lya Mize, meaning "the day of Mize," is the grand annual ceremony
        of the Luvale people held in Zambezi District, Northwestern Province. At its
        heart are the Makishi — masked ancestral spirits who emerge from the forest
        to guide, bless, and educate the community, culminating in the graduation
        of young men from the sacred Mukanda initiation rite.
      </p>

      <div class="llm-stats-row">
        <div class="llm-stat">
          <span class="llm-stat-num">3</span>
          <span class="llm-stat-label">Days of Ceremony</span>
        </div>
        <div class="llm-stat llm-stat-border">
          <span class="llm-stat-num">20+</span>
          <span class="llm-stat-label">Makishi Characters</span>
        </div>
        <div class="llm-stat">
          <span class="llm-stat-num">Aug</span>
          <span class="llm-stat-label">Annual Gathering</span>
        </div>
      </div>
    </div>

    <div class="llm-intro-image scroll-reveal" style="--delay: 0.2s">
      <div class="llm-img-frame llm-img-frame-tilt">
        <img src="/images/mize/mize_logo.png"
             class="llm-img-content"
             alt="Makishi masked spirit at Likumbi Lya Mize"
             loading="lazy" />
        <div class="llm-img-overlay">
          <p class="llm-img-label">THE MAKISHI SPIRITS</p>
          <p class="llm-img-caption">Mize Village, Zambezi District</p>
        </div>
      </div>

      <div class="llm-float-card llm-float-card-tr scroll-reveal" style="--delay: 0.4s">
        <span class="llm-float-icon">📅</span>
        <span class="llm-float-meta">When</span>
        <strong>July 27 · 2026</strong>
      </div>

      <div class="llm-float-card llm-float-card-bl scroll-reveal" style="--delay: 0.6s">
        <span class="llm-float-icon">📍</span>
        <span class="llm-float-meta">Where</span>
        <strong>Mize Village, Zambezi, NW Zambia</strong>
      </div>
    </div>

  </div>
</section>

<%!-- ============================
  TIMELINE / CEREMONY
============================= --%>
<section id="ceremony" class="llm-section llm-section-mid llm-section-earth">
  <div class="llm-container">
    <div class="llm-section-header scroll-reveal">
      <h2 class="llm-section-title llm-text-center">
        A Day in the <em class="llm-gold">Forest</em>
      </h2>
      <p class="llm-section-sub">
        Follow the sacred ceremony from cool dawn drumbeats to the firelit celebrations of night
      </p>
    </div>

    <div class="llm-timeline">
      <div class="llm-timeline-spine" aria-hidden="true"></div>

      <%= for {event, idx} <- Enum.with_index(@timeline_events) do %>
        <div class={["llm-timeline-item",
                     if(rem(idx, 2) == 0, do: "llm-align-right", else: "llm-align-left"),
                     "scroll-reveal"]}
             style={"--delay: #{idx * 0.15}s"}>

          <div class="llm-timeline-text">
            <span class="llm-timeline-time">
              <span class="llm-timeline-icon-sm">◈</span>
              <%= event.time %>
            </span>
            <h3 class="llm-timeline-title"><%= event.title %></h3>
            <p class="llm-timeline-desc"><%= event.description %></p>
          </div>

          <div class="llm-timeline-card">
            <div class="llm-timeline-card-inner">
              <img src={event.image} alt={event.image_alt}
                   loading="lazy" class="llm-timeline-img" />
            </div>
            <div class="llm-timeline-dot" aria-hidden="true"></div>
          </div>

        </div>
      <% end %>
    </div>
  </div>
</section>

<%!-- ============================
  MAKISHI SPIRITS
  (mirrors the Nalikwanda barge / Inkosi regalia section)
============================= --%>
<section id="makishi" class="llm-section llm-section-dark llm-section-mask">
  <div class="llm-dot-grid" aria-hidden="true"></div>

  <div class="llm-container">
    <div class="llm-section-header scroll-reveal">
      <h2 class="llm-section-title llm-text-center">
        The <em class="llm-gold">Makishi</em>
      </h2>
      <p class="llm-section-sub">
        Ancestral spirits clothed in bark-cloth and vivid masks — the living bridge
        between the Luvale people and those who came before
      </p>
    </div>

    <div class="llm-makishi-grid">

      <%!-- Main mask image with hotspots --%>
      <div class="llm-makishi-main scroll-reveal">
        <div class="llm-mask-wrap">
          <img src="/images/mize/mask.jpg"
               alt="Makishi masked spirits" loading="lazy" class="llm-mask-img" />
          <div class="llm-mask-vignette"></div>

          <button class="llm-hotspot llm-hotspot-mwana"
            phx-click="show_makishi" phx-value-type="mwana_pwo"
            title="Mwana Pwo">
            <span class="llm-hotspot-pulse"></span>
            <span class="llm-hotspot-label">Mwana Pwo</span>
          </button>

          <button class="llm-hotspot llm-hotspot-chihongo"
            phx-click="show_makishi" phx-value-type="chihongo"
            title="Chihongo">
            <span class="llm-hotspot-pulse"></span>
            <span class="llm-hotspot-label">Chihongo</span>
          </button>

          <button class="llm-hotspot llm-hotspot-chikuza"
            phx-click="show_makishi" phx-value-type="chikuza"
            title="Chikuza">
            <span class="llm-hotspot-pulse"></span>
            <span class="llm-hotspot-label">Chikuza</span>
          </button>

          <div class="llm-mask-caption">
            <h3>The Sacred Spirits</h3>
            <p>Tap each spirit to learn their role in the ceremony</p>
          </div>
        </div>
      </div>

      <%!-- Detail panels --%>
      <div class="llm-makishi-details scroll-reveal" style="--delay: 0.2s">
        <%= for detail <- @makishi_details do %>
          <div class={"llm-detail-card #{if @active_makishi == detail.id, do: "active"}"}>
            <div class="llm-detail-icon-wrap">
              <span class="llm-detail-icon">
                <%= case detail.icon do
                  "grace"    -> "◎"
                  "power"    -> "◈"
                  "ceremony" -> "⬡"
                  _          -> "◆"
                end %>
              </span>
            </div>
            <div>
              <h4 class="llm-detail-title"><%= detail.title %></h4>
              <p class="llm-detail-desc"><%= detail.description %></p>
            </div>
          </div>
        <% end %>

        <div class="llm-spirit-facts scroll-reveal" style="--delay: 0.4s">
          <h4 class="llm-specs-title">Spirit Facts</h4>
          <ul class="llm-specs-list">
            <li><span>Origin</span><span class="llm-gold">Sacred Forest of Mize</span></li>
            <li><span>Costume</span><span class="llm-gold">Bark-cloth &amp; carved mask</span></li>
            <li><span>Purpose</span><span class="llm-gold">Ancestral guidance</span></li>
            <li><span>Performers</span><span class="llm-gold">Male initiates only</span></li>
          </ul>
        </div>
      </div>

    </div>
  </div>
</section>

<%!-- ============================
  CULTURAL SIGNIFICANCE
============================= --%>
<section id="culture" class="llm-section llm-section-mid llm-section-culture">
  <div class="llm-container llm-grid-2col">

    <div class="llm-culture-mosaic llm-order-2 scroll-reveal">
      <div class="llm-mosaic-col llm-mosaic-col-offset">
        <div class="llm-mosaic-img llm-tall">
          <img src="/images/mize/mize_mukanda.jpg"
               alt="Mukanda initiation ceremony" loading="lazy" />
        </div>
        <div class="llm-mosaic-img llm-medium">
          <img src="/images/mize/mize_elders.jpg"
               alt="Luvale elders" loading="lazy" />
        </div>
      </div>
      <div class="llm-mosaic-col">
        <div class="llm-mosaic-img llm-short">
          <img src="/images/mize/mize_drums.jpg"
               alt="Ceremonial drums" loading="lazy" />
        </div>
        <div class="llm-mosaic-img llm-tall">
          <img src="/images/mize/mize_craft.jpg"
               alt="Mask carving craft" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="llm-culture-text llm-order-1 scroll-reveal" style="--delay: 0.2s">
      <h2 class="llm-section-title">
        Living <em class="llm-gold">Heritage</em>
      </h2>

      <div class="llm-culture-points">
        <div class="llm-culture-point">
          <div class="llm-point-icon">◎</div>
          <div>
            <h3>Rite of Passage</h3>
            <p>
              The Mukanda initiation is the ceremony's sacred core — young men emerge
              from seclusion as full members of Luvale society, shaped by the teachings
              of the Makishi and the wisdom of the elders.
            </p>
          </div>
        </div>

        <div class="llm-culture-point">
          <div class="llm-point-icon">◈</div>
          <div>
            <h3>Ancestral Connection</h3>
            <p>
              The Makishi are not mere costumes — they are believed to be the physical
              manifestation of ancestors returned. Their presence dissolves the boundary
              between the living and those who came before.
            </p>
          </div>
        </div>

        <div class="llm-culture-point">
          <div class="llm-point-icon">⬡</div>
          <div>
            <h3>UNESCO Recognition</h3>
            <p>
              The Makishi masquerade is inscribed on UNESCO's Representative List of
              the Intangible Cultural Heritage of Humanity, affirming its global
              significance and the need for its careful preservation.
            </p>
          </div>
        </div>
      </div>

      <a href="#" class="llm-btn-outline-gold llm-mt-8 inline-flex items-center gap-2">
        Explore Full History <span>→</span>
      </a>
    </div>

  </div>
</section>

<%!-- ============================
  AUDIO EXPERIENCE
============================= --%>
<section class="llm-section llm-section-dark llm-audio-section">
  <div class="llm-container llm-narrow llm-text-center">
    <span class="llm-audio-icon-lg">♩</span>
    <h2 class="llm-section-title">The Drumbeat of the Ancestors</h2>
    <p class="llm-section-sub">
      Listen to the traditional Luvale ceremonial drums and call-and-response chants
      that pulse through Mize village during the ceremony
    </p>

    <div class="llm-player scroll-reveal" id="player-hook" phx-hook="Player">
      <div class="llm-player-controls">
        <button class="llm-ctrl-btn" id="skip-back" aria-label="Skip backward">⏮</button>
        <button class="llm-ctrl-btn llm-ctrl-play" id="play-btn" aria-label="Play/Pause">▶</button>
        <button class="llm-ctrl-btn" id="skip-fwd" aria-label="Skip forward">⏭</button>
      </div>

      <div class="llm-player-progress">
        <span id="current-time" class="llm-time-label">0:00</span>
        <div class="llm-progress-track" id="progress-track" role="progressbar">
          <div class="llm-progress-fill" id="progress-fill" style="width: 0%"></div>
        </div>
        <span class="llm-time-label">4:12</span>
      </div>

      <div class="llm-player-volume">
        <span>🔈</span>
        <input type="range" min="0" max="100" value="70" id="volume-range" aria-label="Volume" />
      </div>
    </div>
  </div>
</section>

<%!-- ============================
  VISITOR GUIDE
============================= --%>
<section id="visit" class="llm-section llm-section-mid llm-section-visit">
  <div class="llm-container">
    <div class="llm-section-header scroll-reveal">
      <h2 class="llm-section-title llm-text-center">
        Plan Your <em class="llm-gold">Journey</em>
      </h2>
      <p class="llm-section-sub">Everything you need to experience Likumbi Lya Mize</p>
    </div>

    <div class="llm-guide-grid scroll-reveal" style="--delay: 0.1s">

      <div class="llm-guide-card">
        <div class="llm-guide-icon">🗓</div>
        <h3>When to Visit</h3>
        <p>
          The ceremony is held annually in August. Arrive a day early to witness village
          preparations and secure a good vantage point at the ceremonial ground in Mize.
        </p>
      </div>

      <div class="llm-guide-card">
        <div class="llm-guide-icon">👗</div>
        <h3>What to Wear</h3>
        <p>
          Dress modestly and respectfully. Earth tones and traditional chitenge fabric
          are welcomed. Avoid bright colours that may clash with the ceremonial dress
          of participants.
        </p>
      </div>

      <div class="llm-guide-card">
        <div class="llm-guide-icon">📷</div>
        <h3>Photography</h3>
        <p>
          Always seek permission before photographing individuals, especially elders and
          initiates. Some Makishi characters may not be photographed — respect any
          restriction given by ceremony guides immediately.
        </p>
      </div>

      <div class="llm-guide-card">
        <div class="llm-guide-icon">🏕</div>
        <h3>Accommodation</h3>
        <p>
          Zambezi Waterfront Lodge and local guesthouses fill quickly. Book at least
          six weeks in advance. Eco-camping near the Zambezi River offers an immersive
          option for budget travellers.
        </p>
      </div>

      <div class="llm-guide-card">
        <div class="llm-guide-icon">🍲</div>
        <h3>Food &amp; Drink</h3>
        <p>
          Try nshima with dried Zambezi fish, chikanda (African polony), and ifisashi
          groundnut stew from stalls at the market adjacent to the ceremonial ground
          on ceremony days.
        </p>
      </div>

      <div class="llm-guide-card">
        <div class="llm-guide-icon">🤝</div>
        <h3>Cultural Etiquette</h3>
        <p>
          Greet elders first and do not stand above a seated elder. If a Makishi
          approaches you, remain still and composed — running or mocking is deeply
          disrespectful and disrupts the sacred atmosphere.
        </p>
      </div>

    </div>
  </div>
</section>

</Layouts.unauth_app>
